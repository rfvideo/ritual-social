# ─────────────────────────────────────────────────────────────────────────────
# RITUAL CHAIN — fill these with your RPC access
# ─────────────────────────────────────────────────────────────────────────────
VITE_RITUAL_CHAIN_ID=560000
VITE_RITUAL_CHAIN_NAME="Ritual Chain Testnet"
VITE_RITUAL_RPC_URL=https://your-ritual-rpc-endpoint
VITE_RITUAL_EXPLORER_URL=https://your-ritual-explorer-endpoint
VITE_RITUAL_NATIVE_SYMBOL=RITUAL
VITE_RITUAL_NATIVE_DECIMALS=18

# WalletConnect (free project id at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Deployed contract addresses (output of `forge script` in /contracts)
VITE_RITUAL_SOCIAL_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# Action fee (native token). Must match actionFee in RitualSocial.sol.
VITE_ACTION_FEE=0.005

# ─────────────────────────────────────────────────────────────────────────────
# RITUAL ON-CHAIN LLM PRECOMPILE (ritualLLM.ts / useRitualModeration.ts)
#
# These are used by the browser-side Ritual LLM path (callRitualLLM).
# The precompile address and TEEServiceRegistry are on Ritual Chain — no
# config needed for those. You only need PINATA_JWT so the Netlify function
# ritual-da-secrets.ts can encrypt your DA credentials for the TEE executor.
# The model (zai-org/GLM-4.7-FP8) and executor selection are automatic.
# ─────────────────────────────────────────────────────────────────────────────
# (PINATA_JWT is also used for IPFS storage — see below)

# ─────────────────────────────────────────────────────────────────────────────
# DECENTRALIZED STORAGE — IPFS image hosting
# Only one provider is required. The Netlify function ipfs-upload.ts reads
# STORAGE_PROVIDER to decide which credentials to use.
# ─────────────────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=web3storage      # "web3storage" or "pinata"
WEB3_STORAGE_TOKEN=
PINATA_JWT=
VITE_IPFS_GATEWAY=https://w3s.link/ipfs/

# ─────────────────────────────────────────────────────────────────────────────
# INFERNET AI CONTAINERS — self-hosted compute layer
#
# Run `docker compose up --build` inside /infernet-containers to start:
#   ritual-translate  — facebook/nllb-200-distilled-600M  (200+ languages)
#   ritual-caption    — Salesforce/blip-image-captioning-base (vision → text)
#   ritual-moderate   — unitary/toxic-bert + regex heuristics
#   ritual-summarize  — facebook/bart-large-cnn (abstractive summarization)
#   ritual-recommend  — engagement-gravity ranking (no model download)
#
# Point INFERNET_ROUTER_URL at wherever the router service is reachable.
# Until this is set, every AI feature falls back to local heuristics and
# the fallback is clearly labeled in the response (model field ends in
# "-local-fallback"). The on-chain Ritual LLM path (useRitualModeration,
# useRitualLLM.ts hooks) is independent and always hits Ritual Chain directly.
# ─────────────────────────────────────────────────────────────────────────────
INFERNET_ROUTER_URL=http://your-infernet-node-host:4000
INFERNET_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# NETLIFY — required for Netlify Blobs (feed index, activity, follow graph)
# These are injected automatically in Netlify's build/function environment.
# Only needed if you run `netlify dev` locally without `netlify login`.
# ─────────────────────────────────────────────────────────────────────────────
# NETLIFY_SITE_ID=
# NETLIFY_BLOBS_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# CONTRACTS — deployer key used ONLY by /contracts/script, never exposed
# to the frontend or any Netlify function.
# ─────────────────────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
