# ─────────────────────────────────────────────────────────────
# RITUAL CHAIN — fill these with the RPC access you already have
# ─────────────────────────────────────────────────────────────
VITE_RITUAL_CHAIN_ID=560000
VITE_RITUAL_CHAIN_NAME="Ritual Chain Testnet"
VITE_RITUAL_RPC_URL=https://your-ritual-rpc-endpoint
VITE_RITUAL_EXPLORER_URL=https://your-ritual-explorer-endpoint
VITE_RITUAL_NATIVE_SYMBOL=RITUAL
VITE_RITUAL_NATIVE_DECIMALS=18

# WalletConnect (get a free project id at cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Deployed contract addresses (filled in after `npm run deploy` in /contracts)
VITE_RITUAL_SOCIAL_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RITUAL_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# Action fee, in native token, must match the value hardcoded in RitualSocial.sol
VITE_ACTION_FEE=0.005

# ─────────────────────────────────────────────────────────────
# DECENTRALIZED STORAGE — image hosting (Web3.Storage / Pinata / any
# IPFS pinning service). Blockchain only ever stores the resulting CID.
# ─────────────────────────────────────────────────────────────
STORAGE_PROVIDER=web3storage
WEB3_STORAGE_TOKEN=
PINATA_JWT=
VITE_IPFS_GATEWAY=https://w3s.link/ipfs/

# ─────────────────────────────────────────────────────────────
# INFERNET — AI compute. Point this at the Infernet Router/Node you
# run yourself (see /infernet-containers for deployable job containers).
# Netlify functions in /netlify/functions proxy to this URL and will
# NOT call any third-party AI vendor directly.
# ─────────────────────────────────────────────────────────────
INFERNET_ROUTER_URL=http://your-infernet-node-host:4000
INFERNET_API_KEY=

# Deployer key used only by contracts/script — never exposed to the frontend
DEPLOYER_PRIVATE_KEY=
